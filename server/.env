# ── Email / SMTP settings ──────────────────────────────────────
# HOW TO SET UP GMAIL:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Go to App Passwords → generate one for "Mail"
#   4. Paste the 16-character app password as EMAIL_PASS below
#   5. Replace EMAIL_USER with your Gmail address
#
# If EMAIL_USER / EMAIL_PASS are left as placeholders,
# the reset link will be printed to the server console instead.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16char_app_password
EMAIL_FROM=CargoFlow <your_email@gmail.com>

# Legacy aliases (also supported)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16char_app_password
SMTP_FROM=CargoFlow <your_email@gmail.com>
